{
  "name": "fundship",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,app -c cyan,green \"npm:dev:api\" \"npm:dev:app\"",
    "dev:app": "vite --host 0.0.0.0",
    "dev:api": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "android:web": "tsc -b && VITE_API_URL=http://localhost:8787/api vite build",
    "android:build": "cd andriod && ./gradlew assembleDebug",
    "android:verify": "npm run check && npm run smoke && cd andriod && ./gradlew assembleDebug lintDebug testDebugUnitTest",
    "android:install": "adb reverse tcp:8787 tcp:8787 && adb install -r andriod/app/build/outputs/apk/debug/app-debug.apk && adb shell am start -n com.sajilo.split/.MainActivity",
    "android:open": "cap open android",
    "check": "tsc -b",
    "smoke": "tsx server/smoke.ts",
    "start": "NODE_ENV=production tsx server/index.ts",
    "user:create": "tsx scripts/create-user.ts",
    "ci": "npm run check && npm run smoke && npm run build"
  },
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/app": "^8.0.0",
    "@capacitor/core": "^8.4.2",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/status-bar": "^8.0.0",
    "@sbmdkl/nepali-date-converter": "^2.0.5",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "lucide-react": "^0.468.0",
    "postgres": "^3.4.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "~5.7.2",
    "vite": "^6.0.5"
  }
}
