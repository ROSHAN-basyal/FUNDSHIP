# Local development uses SQLite automatically when DATABASE_URL is absent.
PORT=8787

# Production: copy the Supabase transaction-pooler URI (port 6543), not the
# direct connection URI. Replace the placeholders and set this only as a secret.
DATABASE_URL=postgres://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_SSL=require
DATABASE_POOL_SIZE=1

# Set the same random secret in Vercel. Vercel Cron sends it as a Bearer token.
CRON_SECRET=replace-with-a-long-random-secret

# Web client URL. The native Android URL is configured at build time with
# FUNDSHIP_API_URL, documented in README.md.
VITE_API_URL=http://localhost:8787/api
