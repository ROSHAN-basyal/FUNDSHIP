{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/[...path].ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/maintenance",
      "schedule": "15 18 * * *"
    }
  ]
}
