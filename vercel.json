{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "supportsCancellation": true
    }
  },
  "fluid": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api?__fundship_path=:path*"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/maintenance",
      "schedule": "15 18 * * *"
    }
  ]
}
